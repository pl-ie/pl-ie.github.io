#!/bin/bash
# MTP v1.2 - Media Tail Player
# Play .part files while downloading, recording or generating TTS
# r = refresh (resume with more buffer)
# q = quit (saves position)

G='\033[1;32m'
Y='\033[1;33m'
C='\033[1;36m'
M='\033[1;35m'
R='\033[0m'

WATCH_LATER_BASE="$HOME/.config/mpv/watch_later"
mkdir -p "$WATCH_LATER_BASE"

# === FUNCTIONS ===

_session_dir() {
    local file="$1"
    # Strip .part suffix so .part and its final file share the same session dir
    local base="${file%.part}"
    local stem="${base%.*}"
    local safe
    safe=$(echo "$stem" | tr '/' '_' | tr ' ' '_')
    echo "$WATCH_LATER_BASE/sessions/${safe}"
}

_wait_for_min_size() {
    local file="$1"
    [[ "$file" != *.part ]] && return 0

    local size
    size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)
    if (( size < 1048576 )); then
        echo -e "${Y}⏳ Waiting for minimum size: 1 MB${R}"
        while (( size < 1048576 )); do
            sleep 1
            size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)
            local size_mb
            size_mb=$(echo "scale=2; $size / 1048576" | bc)
            echo -ne "\r${M}📊 Size: ${size_mb} MB  ${R}"
        done
        local size_mb
        size_mb=$(echo "scale=2; $size / 1048576" | bc)
        echo -e "\n${G}✅ Minimum size reached: ${size_mb} MB${R}"
    fi
}

_create_input_conf() {
    local conf="$1"
    cat > "$conf" <<'EOF'
SPACE cycle pause
9 add volume -5
0 add volume +5
, seek -10 relative+keyframes
. seek +10 relative+keyframes
LEFT seek -20 relative+keyframes
RIGHT seek +20 relative+keyframes
UP seek +120 relative+keyframes
DOWN seek -120 relative+keyframes
HOME seek 0 absolute
r seek 0 absolute
o show-text "Buffer: ${demuxer-cache-duration}s | ${demuxer-cache-time}s cached" 5000
e quit 3
u quit 42
q quit 4
EOF
}

_show_file_info() {
    local file="$1"
    local size_mb
    size_mb=$(echo "scale=2; $(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null) / 1048576" | bc)
    local session_dir
    session_dir=$(_session_dir "$file")

    echo -e "${C}____________________________________________________________${R}"
    echo -e "${C}  MTP v1.2 | MEDIA TAIL PLAYER                            ${R}"
    echo -e "${C}____________________________________________________________${R}"
    echo -e "${Y}  9 / 0    : Volume down / up                ${R}"
    echo -e "${Y}  , / .    : Seek -10 / +10 sec              ${R}"
    echo -e "${Y}  ← / →    : Seek -20 / +20 sec              ${R}"
    echo -e "${Y}  ↑ / ↓    : Seek +120 / -120 sec            ${R}"
    echo -e "${Y}  SPACE    : Pause / Resume                  ${R}"
    echo -e "${Y}  r / HOME : Restart file          ${R}"
    echo -e "${Y}  o        : OSD cache info                   ${R}"
    echo -e "${Y}  e        : EOF menu (resume/restart)     ${R}"
    echo -e "${Y}  u        : Refresh (more buffer)           ${R}"
    echo -e "${Y}  q        : Quit (saves position)           ${R}"
    echo -e "${C}____________________________________________________________${R}"
    if [[ "$file" == *.part ]]; then
        echo -e "${Y}📥 Downloading (.part)${R}"
    else
        echo -e "${G}✅ Ready${R}"
    fi
    echo -e "${G}🎵 File:${R} $(basename "$file")"
    echo -e "${M}📊 Size:${R} ${size_mb} MB"

    local saved_file
    saved_file=$(find "$session_dir" -type f 2>/dev/null | head -1)
    if [[ -n "$saved_file" ]]; then
        local pos
        pos=$(grep "^start=" "$saved_file" 2>/dev/null | cut -d'=' -f2)
        if [[ -n "$pos" ]]; then
            local min sec
            min=$(echo "scale=0; $pos / 60" | bc 2>/dev/null || echo "0")
            sec=$(printf "%.0f" "$(echo "$pos % 60" | bc 2>/dev/null)" 2>/dev/null || echo "0")
            echo -e "${G}💾 Resuming from:${R} ${min}m ${sec}s"
        fi
    fi
    echo -e "${C}____________________________________________________________${R}"
}

_run_mpv() {
    local file="$1"
    local session_dir
    session_dir=$(_session_dir "$file")
    mkdir -p "$session_dir"

    local input_conf
    input_conf=$(mktemp)
    trap "rm -f '$input_conf'" RETURN
    _create_input_conf "$input_conf"

    local size_at_start
    size_at_start=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)

    local keep_open="no"
    [[ "$file" == *.part ]] && keep_open="yes"

    mpv \
        --keep-open="$keep_open" \
        --no-input-default-bindings \
        --input-conf="$input_conf" \
        --demuxer-lavf-o=fflags=+nobuffer+fastseek \
        --demuxer-readahead-secs=1 \
        --cache=yes \
        --cache-secs=10 \
        --demuxer-max-bytes=50M \
        --demuxer-max-back-bytes=20M \
        --stream-buffer-size=2M \
        --hr-seek=yes \
        --hr-seek-demuxer-offset=0 \
        --save-position-on-quit \
        --resume-playback \
        --watch-later-directory="$session_dir" \
        --title="MTP: $(basename "$file")" \
        "$file"

    local exit_code=$?

    local size_after size_at_start_mb size_after_mb
    size_after=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null || echo "$size_at_start")
    size_at_start_mb=$(echo "scale=2; $size_at_start / 1048576" | bc)
    size_after_mb=$(echo "scale=2; $size_after / 1048576" | bc)
    local size_diff=$(( size_after - size_at_start ))

    echo ""
    echo -e "${C}____________________________________________________________${R}"
    echo -e "${M}📊 Size at start:${R} ${size_at_start_mb} MB"
    echo -e "${M}📊 Size at end:${R}   ${size_after_mb} MB"
    if (( size_diff > 0 )); then
        local size_diff_mb
        size_diff_mb=$(echo "scale=2; $size_diff / 1048576" | bc)
        echo -e "${G}📈 Downloaded during playback:${R} +${size_diff_mb} MB"
    fi
    echo -e "${C}____________________________________________________________${R}"

    return $exit_code
}

_find_base_file() {
    local part_file="$1"
    local base="${part_file%.part}"

    if [[ -f "$base" ]]; then
        echo "$base"
        return 0
    fi

    local stem="${base%.*}"
    local found
    found=$(ls -t "${stem}".mp4 "${stem}".mkv "${stem}".webm \
               "${stem}".m4a "${stem}".mp3 "${stem}".opus \
               "${stem}".ogg "${stem}".flac "${stem}".wav 2>/dev/null | head -1)
    echo "$found"
}

# === FILE SELECTION ===
if [[ -n "$1" ]]; then
    CURRENT_FILE="$1"
    if [[ ! -f "$CURRENT_FILE" ]]; then
        echo -e "${Y}❌ File not found: $CURRENT_FILE${R}"
        exit 1
    fi
    echo -e "${C}📂 File selected from argument${R}"
else
    CURRENT_FILE=$(ls -t *.part 2>/dev/null | head -1)
    if [[ -z "$CURRENT_FILE" ]]; then
        CURRENT_FILE=$(ls -t *.mp4 *.mkv *.webm *.avi *.mp3 *.opus \
                          *.ogg *.m4a *.flac *.wav 2>/dev/null | head -1)
    fi
    if [[ -z "$CURRENT_FILE" ]]; then
        echo -e "${Y}❌ No media files found${R}"
        exit 1
    fi
    echo -e "${C}📂 Auto-selected latest file${R}"
fi

# === MAIN LOOP ===
while true; do
    _wait_for_min_size "$CURRENT_FILE"
    _show_file_info "$CURRENT_FILE"
    _run_mpv "$CURRENT_FILE"
    EXIT_CODE=$?

    # Auto-detect: did .part finish downloading while we were playing?
    if [[ "$CURRENT_FILE" == *.part ]]; then
        BASE=$(_find_base_file "$CURRENT_FILE")
        if [[ -n "$BASE" ]]; then
            echo -e "${G}✨ Download complete: $(basename "$BASE")${R}"
            CURRENT_FILE="$BASE"
        fi
    fi

    if [[ $EXIT_CODE -eq 42 ]]; then
        # u pressed - refresh
        echo -e "${G}🔄 Refreshing...${R}"
        if [[ "$CURRENT_FILE" == *.part ]]; then
            local_size=$(stat -c%s "$CURRENT_FILE" 2>/dev/null || stat -f%z "$CURRENT_FILE" 2>/dev/null)
            local_mb=$(echo "scale=2; $local_size / 1048576" | bc)
            echo -e "${M}📊 Current .part size: ${local_mb} MB${R}"
        else
            echo -e "${G}✅ Resuming from saved position...${R}"
        fi
        sleep 1
        continue

    elif [[ $EXIT_CODE -eq 4 ]]; then
        # q pressed - exit immediately
        break

    elif [[ $EXIT_CODE -eq 3 || $EXIT_CODE -eq 0 ]]; then
        # e pressed or natural EOF - show menu
        echo -e "${G}✅ Playback paused at end of buffer (EOF)${R}"
        echo -e "${C}____________________________________________________________${R}"
        echo -e "${Y}  u / SPACE : Check for more data & Resume${R}"
        echo -e "${Y}  r / HOME  : Restart file${R}"
        echo -e "${Y}  q / Enter : Quit${R}"
        echo -e "${C}____________________________________________________________${R}"

        read -r -s -n 1 choice
        if [[ "$choice" == "u" || "$choice" == "U" || "$choice" == " " ]]; then
            # Check if .part became a completed file before resuming
            if [[ "$CURRENT_FILE" == *.part ]]; then
                BASE=$(_find_base_file "$CURRENT_FILE")
                if [[ -n "$BASE" ]]; then
                    echo -e "${G}✨ Switch to completed file: $(basename "$BASE")${R}"
                    CURRENT_FILE="$BASE"
                fi
            fi
            echo -e "${G}🔄 Resuming from last saved position...${R}"
            sleep 1
            continue
        elif [[ "$choice" == "r" || "$choice" == "R" ]]; then
            session=$(_session_dir "$CURRENT_FILE")
            find "$session" -type f -delete 2>/dev/null
            echo -e "${G}⏮  Restarting file...${R}"
            sleep 1
            continue
        else
            break
        fi

    else
        break
    fi
done
